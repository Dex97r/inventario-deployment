# =========================================================================
# CONFIGURACIÓN UNIFICADA DE VARIABLES DE ENTORNO PARA DOCKER COMPOSE
# Copie este archivo como '.env' en este mismo directorio y configure sus valores.
# =========================================================================

# --- CONFIGURACIÓN DE BASE DE DATOS DE USUARIOS (db_webapp) ---
DB_WEBAPP_DB=webapp_db
DB_WEBAPP_USER=webapp_user
DB_WEBAPP_PASS=webapp_pass

# --- CONFIGURACIÓN DE BASE DE DATOS DE EQUIPOS (db_api) ---
DB_API_DB=api_db
DB_API_USER=api_user
DB_API_PASS=api_pass

# --- CONFIGURACIÓN DE LA API FastAPI (api_service) ---
# Conexión interna de la API a su base de datos (db_api:5432)
API_DATABASE_URL=postgresql://api_user:api_pass@db_api:5432/api_db

# --- CONFIGURACIÓN DE LA WEBAPP Flask (webapp) ---
# Conexión interna de la WebApp a su base de datos de usuarios (db_webapp:5432)
WEBAPP_DATABASE_URL=postgresql://webapp_user:webapp_pass@db_webapp:5432/webapp_db

# URL interna para consumir la API FastAPI de equipos
WEBAPP_API_URL=http://api_service:8000

# Clave secreta para la sesión y protección CSRF de Flask
WEBAPP_SECRET_KEY=clave_super_secreta_academica
